{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "build": {
        "cmd": ["npm install", "npm run build"],
        "buildPack": "nodejs"
      },
      "start": {
        "cmd": ["npm run start"]
      }
    }
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ON_FAILURE"
  },
  "variables": {
    "PORT": "3001",
    "LMDB_PATH": "/app/data/courses.lmdb"
  }
}